# PixelArena Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Client URL (for CORS in production)
CLIENT_URL=http://localhost:5173

# Google Gemini API (Free tier - needed for Phase 2+ AI features)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Game Defaults (override as needed)
DEFAULT_GRID_SIZE=1080
MAX_PLAYERS_PER_ROOM=20
ROUND_TIME_SECONDS=80
MAX_ROUNDS=3
